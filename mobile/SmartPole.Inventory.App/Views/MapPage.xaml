<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             xmlns:vm="clr-namespace:SmartPole.Inventory.MobileCore.ViewModels;assembly=SmartPole.Inventory.MobileCore"
             x:Class="SmartPole.Inventory.App.Views.MapPage"
             x:DataType="vm:MapViewModel"
             Title="{Binding Title}">

    <Grid>
        <mapsui:MapView x:Name="mapView"
                        VerticalOptions="FillAndExpand"
                        HorizontalOptions="FillAndExpand" />

        <VerticalStackLayout VerticalOptions="End" HorizontalOptions="End" Margin="20" Spacing="10">
            <Button Text="📍"
                    Command="{Binding UpdateCurrentLocationCommand}"
                    WidthRequest="50"
                    HeightRequest="50"
                    CornerRadius="25" />
            <Button Text="🔄"
                    Command="{Binding LoadPolesCommand}"
                    WidthRequest="50"
                    HeightRequest="50"
                    CornerRadius="25" />
        </VerticalStackLayout>
        
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>
</ContentPage>
